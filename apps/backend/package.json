{
  "name": "project-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "docker:start": "npm install && node src/index.js",
    "db:migrate": "npx prisma@5.19.0 migrate dev",
    "db:push": "npx prisma@5.19.0 db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma@5.19.0 studio",
    "prisma:generate": "npx prisma@5.19.0 generate"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "prisma": "^5.19.0"
  }
}
